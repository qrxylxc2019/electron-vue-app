{
  "name": "electron-vue-quiz",
  "version": "1.0.0",
  "description": "做题软件",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:renderer": "vite",
    "build:main": "tsc --project src/main/tsconfig.json",
    "build": "npm run build:main && vite build && npx @electron/rebuild -f && electron-builder",
    "build:win": "npm run build:main && vite build && electron-builder --win --x64",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node-fetch": "^2.6.13",
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.3.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.0.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-vue": "^5.1.12",
    "better-sqlite3": "^12.10.0",
    "element-plus": "^2.9.0",
    "marked": "^18.0.3",
    "node-fetch": "^2.7.0",
    "openai": "^6.37.0",
    "sqlite3": "^6.0.1",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "wasmtime": "^0.0.2"
  },
  "build": {
    "appId": "com.example.quiz",
    "productName": "做题软件",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "out/data/qingrui.db",
        "to": "data/qingrui.db"
      },
      {
        "from": "src/main/deepseek",
        "to": "deepseek"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": "x64"
        }
      ],
      "artifactName": "${productName}.exe"
    },
    "portable": {
      "artifactName": "做题软件.exe"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ]
  }
}
